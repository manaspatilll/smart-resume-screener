# Ollama local server
OLLAMA_HOST=http://localhost:11434

# Extraction (resume/JD -> structured JSON): mechanical task, small model is fine
OLLAMA_EXTRACTION_MODEL=llama3.2

# Scoring (judgment call): keep the larger model for reasoning quality
OLLAMA_SCORING_MODEL=llama3.2

# Score threshold for "shortlisted" tag (0-100)
SHORTLIST_THRESHOLD=70

# SQLite file path
DATABASE_PATH=./resume_screener.db